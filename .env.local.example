NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Magic-link redirects (no trailing slash). On Vercel Preview you can omit this — the app falls back to https://$VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
# Optional: feature a collection on /shop; if empty or no match, all products are listed
NEXT_PUBLIC_SHOPIFY_COLLECTION_HANDLE=

# Comma-separated Shopify Storefront variant GIDs for protocol starter checkout (server-side)
PROTOCOL_VARIANT_IDS_L1=
PROTOCOL_VARIANT_IDS_L2=
PROTOCOL_VARIANT_IDS_L3=

OPENAI_API_KEY=your_openai_api_key
KLAVIYO_API_KEY=your_klaviyo_api_key
RESEND_API_KEY=your_resend_api_key

NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

NEXT_PUBLIC_PRODUCT_PATH=own-brand
NEXT_PUBLIC_CONSULT_ENABLED=false
NEXT_PUBLIC_AI_COMPANION_ENABLED=false
NEXT_PUBLIC_ESTROGEN_TEASER_ENABLED=true
NEXT_PUBLIC_DASHBOARD_ENABLED=false
